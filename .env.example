# ─────────────────────────────────────────────────────────────────────────────
# MINDFORGE — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development             # development | production
APP_SECRET_KEY=change-me-please
DEBUG=true

# ─── Server ───────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=5173
CORS_ORIGINS=http://localhost:5173

# ─── Google Gemini ────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro-latest

# ─── LangChain ────────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-api-key-here   # optional — for LangSmith tracing
LANGCHAIN_PROJECT=MINDFORGE

# ─── Selenium / Browser Automation ───────────────────────────────────────────
BROWSER_HEADLESS=false          # true in production / CI
BROWSER_TIMEOUT=30              # seconds
SELENIUM_REMOTE_URL=            # optional — e.g. http://selenium-hub:4444/wd/hub

# ─── Voice ────────────────────────────────────────────────────────────────────
VOICE_ENGINE=google             # google | whisper
WHISPER_MODEL_SIZE=base         # tiny | base | small | medium | large
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_SIZE=1024

# ─── Database (optional — for task persistence) ───────────────────────────────
DATABASE_URL=sqlite:///./mindforge.db
# DATABASE_URL=postgresql://user:password@localhost:5432/mindforge

# ─── Redis (optional — for task queue / caching) ─────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
LOG_FILE=logs/mindforge.log
