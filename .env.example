# 🧠 MINDFORGE ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your values.

# ─── 1. GOOGLE GEMINI API CONFIGURATION ──────────────────────────────────────
# Get your key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro-latest

# ─── 2. DATABASE CONFIGURATION ──────────────────────────────────────────────
# MariaDB is recommended. Format: mysql+aiomysql://user:password@host:port/dbname
DB_HOST=localhost
DB_PORT=3306
DB_USER=mindforge_user
DB_PASSWORD=mindforge_password
DB_NAME=mindforge_db
# Set the full URL for the app to use
DATABASE_URL=sqlite+aiosqlite:///./mindforge.db

# ─── 3. VOICE / SPEECH API KEYS ───────────────────────────────────────────────
# Voice engine options: google (default), whisper, elevenlabs
VOICE_ENGINE=google
# Required if using cloud-based STT/TTS services
STT_API_KEY=
TTS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── 4. BROWSER AUTOMATION SETTINGS ─────────────────────────────────────────
BROWSER_HEADLESS=false          # Set to true for background execution
BROWSER_TIMEOUT=30              # Seconds to wait for page loads
# If using a remote Selenium grid (e.g. Docker)
# SELENIUM_REMOTE_URL=http://localhost:4444/wd/hub

# ─── 5. SECURITY KEYS & SECRETS ───────────────────────────────────────────────
# Generate secure strings using: openssl rand -hex 32
APP_SECRET_KEY=generate-a-strong-secret-key-for-session-signing
JWT_SECRET_KEY=generate-a-different-strong-secret-for-jtws
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration (Comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── 6. LOGGING CONFIGURATION ─────────────────────────────────────────────────
# Log levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FILE=logs/mindforge.log
ENABLE_FILE_LOGGING=true

# ─── 7. DEVELOPMENT / PRODUCTION FLAGS ────────────────────────────────────────
# Env options: development, staging, production
APP_ENV=development
DEBUG=true                      # Enable/disable FastAPI debug mode
